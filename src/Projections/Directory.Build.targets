<Project ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" >

  <Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Build.targets', '$(MSBuildThisFileDirectory)../'))" />

  <!--
    All projection projects under src/Projections/ go through the new C# 'cswinrtprojectionrefgen'
    tool (via the CsWinRTGenerateProjection MSBuild target). Add a project reference so that the
    generator binary is built before the projection project's CsWinRTGenerateProjection target runs.
    For NuGet consumers, the tool is shipped in the package and this reference is unnecessary.
  -->
  <ItemGroup>
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\WinRT.Projection.Ref.Generator\WinRT.Projection.Ref.Generator.csproj" ReferenceOutputAssembly="false" />
  </ItemGroup>

</Project>
