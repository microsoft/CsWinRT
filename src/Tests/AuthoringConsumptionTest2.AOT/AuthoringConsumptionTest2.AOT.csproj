<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows10.0.26100.1</TargetFramework>
    <Platforms>x64</Platforms>
    <RuntimeIdentifiers>win-x64</RuntimeIdentifiers>

    <!-- Source generator emits the merged ABI.{AssemblyName}.ManagedExports.GetActivationFactory
         dispatcher walking each referenced component's ManagedExports. -->
    <CsWinRTMergeReferencedActivationFactories>true</CsWinRTMergeReferencedActivationFactories>

    <!-- AOT publish into a single self-contained native dll exporting DllGetActivationFactory. -->
    <PublishAot>true</PublishAot>
    <NativeLib>Shared</NativeLib>
    <SelfContained>true</SelfContained>
    <OutputType>Exe</OutputType>
    <CustomNativeMain>true</CustomNativeMain>
    <IsTrimmable>true</IsTrimmable>
  </PropertyGroup>

  <ItemGroup>
    <!--
      AuthoringTest defaults to PublishAot in its Directory.Build.props for Release|x64
      (used by AuthoringConsumptionTest's single-component AOT scenario). This .AOT host
      bundles AuthoringTest as a managed-only input - we want it built as a plain CsWinRT
      component library so its bin doesn't pull in the WinAppSDK runtime payload (which
      would collide with our own AOT publish closure on NETSDK1152). Pass the opt-out
      property to suppress that block.
    -->
    <ProjectReference Include="..\AuthoringTest\AuthoringTest.csproj">
      <Properties>_AuthoringTestSkipAotPublishConfig=true</Properties>
    </ProjectReference>
    <ProjectReference Include="..\AuthoringTest2\AuthoringTest2.csproj" />
    <ProjectReference Include="..\..\Projections\Windows\Windows.csproj" />
    <ProjectReference Include="..\..\Authoring\WinRT.SourceGenerator2\WinRT.SourceGenerator2.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\cswinrt\cswinrt.vcxproj" />
  </ItemGroup>

  <ItemGroup>
    <!--
      AuthoringTest declares <PackageReference Include="Microsoft.Web.WebView2" ExcludeAssets="all"/>
      which suppresses WebView2 in AuthoringTest's own compile but does NOT block transitive
      flow to consumers. WebView2's Microsoft.Web.WebView2.Core.Projection.dll embeds an
      assembly reference to the official signed Microsoft.Windows.SDK.NET (Version=10.0.17763.38,
      PKT=31bf3856ad364e35), which RAR cannot unify with our locally-built unsigned v1.0.0.0 -
      manifests as NETSDK1148 here.

      Add the PackageReference at the AOT host with ExcludeAssets="all" so this csproj also
      excludes the WebView2 assets from its compile/runtime closure.
    -->
    <PackageReference Include="Microsoft.Web.WebView2">
      <ExcludeAssets>all</ExcludeAssets>
    </PackageReference>
  </ItemGroup>

</Project>
