<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows10.0.26100.1</TargetFramework>
    <Platforms>x64</Platforms>
    <RuntimeIdentifiers>win-x64</RuntimeIdentifiers>

    <!-- Source generator emits the merged ABI.{AssemblyName}.ManagedExports.GetActivationFactory
         dispatcher walking each referenced component's ManagedExports. -->
    <CsWinRTMergeReferencedActivationFactories>true</CsWinRTMergeReferencedActivationFactories>

    <!-- AOT publish into a single self-contained native dll exporting DllGetActivationFactory. -->
    <PublishAot>true</PublishAot>
    <NativeLib>Shared</NativeLib>
    <SelfContained>true</SelfContained>
    <OutputType>Exe</OutputType>
    <CustomNativeMain>true</CustomNativeMain>
    <IsTrimmable>true</IsTrimmable>
      <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\AuthoringTest3\AuthoringTest3.csproj" />
    <ProjectReference Include="..\AuthoringTest2\AuthoringTest2.csproj" />
    <ProjectReference Include="..\..\Projections\Windows\Windows.csproj" />
    <ProjectReference Include="..\..\Authoring\WinRT.SourceGenerator2\WinRT.SourceGenerator2.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\cswinrt\cswinrt.vcxproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- WebView2.Core.Projection.dll references the official signed Microsoft.Windows.SDK.NET,
         which conflicts with our locally-built unsigned one. Exclude WebView2 from this csproj's
         compile/runtime closure to avoid NETSDK1148. -->
    <PackageReference Include="Microsoft.Web.WebView2">
      <ExcludeAssets>all</ExcludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <!-- Component's ABI.{Name}.ManagedExports.GetActivationFactory delegates to the same FQN
         type in WinRT.Component (generated by cswinrtprojectiongen) via UnsafeAccessor. The
         trimmer doesn't follow that cross-assembly string-typed reference, so it drops the
         body holding the activation logic. Root WinRT.Component so all its types survive. -->
    <TrimmerRootAssembly Include="WinRT.Component" />
  </ItemGroup>

  <!-- Build the merged AOT host. slnx/VS solution build calls Build (not Publish), so hook
       Publish onto Build to drive the ILC pipeline. -->
  <Target Name="_RunPublishAfterBuild" AfterTargets="Build" DependsOnTargets="Publish" />

</Project>
