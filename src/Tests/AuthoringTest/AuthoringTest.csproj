<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows10.0.26100.1</TargetFramework>
    <Platforms>x64;x86</Platforms>
    <CsWinRTComponent>true</CsWinRTComponent>
    <IsTrimmable>true</IsTrimmable>
    <TargetPlatformResourceVersion>10.0.18362.0</TargetPlatformResourceVersion>
    <!-- CsWinRTEnableLogging helps to diagnose generation issues -->
    <!-- <CsWinRTEnableLogging>true</CsWinRTEnableLogging> -->
    <!--<CsWinRTKeepGeneratedSources>true</CsWinRTKeepGeneratedSources>--> 
    <RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
	  
    <!-- Using x86 to test compilation of this option -->
    <CsWinRTGenerateOverridedClassNameActivationFactory Condition="'$(Platform)' == 'x86'">true</CsWinRTGenerateOverridedClassNameActivationFactory>

    <CsWinRTGenerateManagedDllGetActivationFactory>true</CsWinRTGenerateManagedDllGetActivationFactory>
	  
    <!--
      Don't fail builds for well known warnings in the authoring tests that are expected:

      "CS0067: The event 'BasicClass.ComplexDelegateEvent' is never used."
      "CS0282: There is no defined ordering between fields in multiple declarations of partial struct 'PartialStruct'.
	      To specify an ordering, all instance fields must be in the same declaration."
      "IL2087: <GuidPatcherImplementationDetails>.<SignatureCache>ABI.Windows.Foundation.AsyncActionProgressHandler<!0>..cctor():
          'type' argument does not satisfy 'DynamicallyAccessedMemberTypes.PublicFields' in call to
          'WinRT.GuidGenerator.GetSignature(Type)'. The generic parameter '!0' of
          '<GuidPatcherImplementationDetails>.<SignatureCache>ABI.Windows.Foundation.AsyncActionProgressHandler<!0>' does not have
          matching annotations. The source value must declare at least the same requirements as those declared on the target
          location it is assigned to."		  
    -->
    <WarningsNotAsErrors>$(WarningsNotAsErrors);CS0067;CS0282;IL2087</WarningsNotAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK.WinUI">
      <!-- Keep build assets imported. -->
      <ExcludeAssets>compile;runtime</ExcludeAssets>
    </PackageReference>
    <!--
      Direct PackageReference to Microsoft.Web.WebView2 (transitively brought in by
      WindowsAppSDK.WinUI). Two roles:

        1. ExcludeAssets=all: with the direct reference present, NuGet treats WebView2 as
           "directly referenced, contributing nothing" for THIS project, which suppresses
           WebView2's buildTransitive auto-import. Without this direct ref, AuthoringTest's
           own build picks up WebView2's buildTransitive Projection.dll
           (Microsoft.Web.WebView2.Core.Projection.dll, a CsWinRT 2.x style projection
           stamped against Microsoft.Windows.SDK.NET v10.0.17763.38 PK=31bf3856ad364e35),
           which conflicts with the in-repo Microsoft.Windows.SDK.NET.dll (v1.0.0.0
           PK=null) and trips NETSDK1148 on AuthoringTest.

        2. PrivateAssets=all: stop WebView2's package assets from flowing to AuthoringTest's
           consumers. The native-consumer aggregator csproj used by AuthoringConsumptionTest
           inherits AuthoringTest's package graph through ProjectReference, and without
           PrivateAssets=all here it would pick up WebView2's buildTransitive Projection.dll
           the same way AuthoringTest would have - tripping NETSDK1148 on the aggregator.
           NuGet's direct-ref-wins (centroid) rule means this PrivateAssets=all is the
           authoritative metadata for WebView2 across the closure, so it also blocks the
           WinUI->WebView2 transitive path.

      We deliberately do NOT set PrivateAssets=all on WindowsAppSDK.WinUI itself: the
      aggregator needs WinUI's WinMD metadata to generate the merged projection .dll for
      Microsoft.UI.Xaml.* types referenced by AuthoringTest.winmd.
    -->
    <PackageReference Include="Microsoft.Web.WebView2">
      <ExcludeAssets>all</ExcludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>
  
  <ItemGroup>    
    <ProjectReference Include="..\..\Projections\Windows\Windows.csproj" />    
    <ProjectReference Include="..\..\Projections\WinAppSDK\WinAppSDK.csproj" />
    <ProjectReference Include="..\..\Authoring\WinRT.SourceGenerator2\WinRT.SourceGenerator2.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\cswinrt\cswinrt.vcxproj" />
  </ItemGroup>

</Project>