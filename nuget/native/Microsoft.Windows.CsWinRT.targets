<!--
***********************************************************************************************
Copyright (C) Microsoft Corporation. All rights reserved.

Targets for native (C++) projects consuming C# WinRT component projects.

When a vcxproj imports this file (typically via the Microsoft.Windows.CsWinRT NuGet's
`build\native\Microsoft.Windows.CsWinRT.targets` auto-import), it walks the resolved
ProjectReference set, picks references whose CsWinRTComponent metadata is 'true', and:

  1. Synthesizes a temporary aggregator csproj in the consumer's intermediate directory
     that ProjectReferences every detected component. The aggregator's TargetFramework
     is taken from the components themselves (which are required to use a Windows-
     targeted TFM such as net10.0-windows10.0.X.Y), so Microsoft.NET.Windows.targets'
     RemoveManagedWinRTComponentWinMDReferences / AddWinRTComponentImplementationReference
     pair fires automatically and re-injects each component's managed implementation .dll
     into the aggregator's Reference set.

  2. Builds the aggregator with CsWinRTBuildForNativeConsumer=true so cswinrt's full
     component / interop / projection generator pipeline runs once across the union
     of all referenced components, producing a single deduplicated WinRT.Interop.dll
     (avoiding type-map duplicate-key collisions that per-component generation would
     hit) along with WinRT.Component.dll, WinRT.Projection.dll, and WinRT.Sdk.Projection.dll.

  3. Copies the generated DLLs from the aggregator's intermediate directory to the
     consumer's output directory, where the C++ host loads them at runtime through
     WinRT.Host.dll / WinRT.Host.Shim.dll.

Properties:
  - CsWinRTDisableNativeComponentInterop: set to 'true' to disable
***********************************************************************************************
-->
<Project ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <_CsWinRTNativeConsumerIntermediateDir>$([MSBuild]::NormalizeDirectory('$(MSBuildProjectDirectory)', '$(IntDir)', 'cswinrt'))</_CsWinRTNativeConsumerIntermediateDir>
  </PropertyGroup>

  <!--
    ============================================================
                _WriteCsWinRTAggregatorPublicKey

    Inline task that writes the CsWinRT public-key blob (160 bytes) to a .snk file at the
    given OutputPath. Same byte sequence the projection generator already uses to delay-sign
    WinRT.Projection.dll and WinRT.Sdk.Projection.dll - see
    src/WinRT.Projection.Generator/Generation/ProjectionGenerator.Emit.cs (CsWinRTPublicKey
    field). Its public key token is 31bf3856ad364e35 (the well-known MS .NET / ECMA libraries
    key), which matches what the interop generator hardcodes for WinRT.Component in
    src/WinRT.Interop.Generator/References/InteropReferences.cs (WinRTComponent property).

    Bundling the bytes inline (rather than shipping a .snk file in the NuGet package) avoids
    distributing any key material as a separate package asset and keeps the source-of-truth in
    one place.
    ============================================================
  -->
  <UsingTask TaskName="_WriteCsWinRTAggregatorPublicKey"
             TaskFactory="RoslynCodeTaskFactory"
             AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <OutputPath ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Code Type="Fragment" Language="cs">
        <![CDATA[
          byte[] bytes = new byte[]
          {
            0x00, 0x24, 0x00, 0x00, 0x04, 0x80, 0x00, 0x00, 0x94, 0x00, 0x00, 0x00, 0x06, 0x02, 0x00, 0x00,
            0x00, 0x24, 0x00, 0x00, 0x52, 0x53, 0x41, 0x31, 0x00, 0x04, 0x00, 0x00, 0x01, 0x00, 0x01, 0x00,
            0xB5, 0xFC, 0x90, 0xE7, 0x02, 0x7F, 0x67, 0x87, 0x1E, 0x77, 0x3A, 0x8F, 0xDE, 0x89, 0x38, 0xC8,
            0x1D, 0xD4, 0x02, 0xBA, 0x65, 0xB9, 0x20, 0x1D, 0x60, 0x59, 0x3E, 0x96, 0xC4, 0x92, 0x65, 0x1E,
            0x88, 0x9C, 0xC1, 0x3F, 0x14, 0x15, 0xEB, 0xB5, 0x3F, 0xAC, 0x11, 0x31, 0xAE, 0x0B, 0xD3, 0x33,
            0xC5, 0xEE, 0x60, 0x21, 0x67, 0x2D, 0x97, 0x18, 0xEA, 0x31, 0xA8, 0xAE, 0xBD, 0x0D, 0xA0, 0x07,
            0x2F, 0x25, 0xD8, 0x7D, 0xBA, 0x6F, 0xC9, 0x0F, 0xFD, 0x59, 0x8E, 0xD4, 0xDA, 0x35, 0xE4, 0x4C,
            0x39, 0x8C, 0x45, 0x43, 0x07, 0xE8, 0xE3, 0x3B, 0x84, 0x26, 0x14, 0x3D, 0xAE, 0xC9, 0xF5, 0x96,
            0x83, 0x6F, 0x97, 0xC8, 0xF7, 0x47, 0x50, 0xE5, 0x97, 0x5C, 0x64, 0xE2, 0x18, 0x9F, 0x45, 0xDE,
            0xF4, 0x6B, 0x2A, 0x2B, 0x12, 0x47, 0xAD, 0xC3, 0x65, 0x2B, 0xF5, 0xC3, 0x08, 0x05, 0x5D, 0xA9
          };
          string dir = System.IO.Path.GetDirectoryName(OutputPath);
          if (!string.IsNullOrEmpty(dir) && !System.IO.Directory.Exists(dir))
          {
              System.IO.Directory.CreateDirectory(dir);
          }
          // Only rewrite if missing or content differs, to preserve incremental build state
          bool needWrite = !System.IO.File.Exists(OutputPath);
          if (!needWrite)
          {
              byte[] existing = System.IO.File.ReadAllBytes(OutputPath);
              needWrite = existing.Length != bytes.Length;
              if (!needWrite)
              {
                  for (int i = 0; i < bytes.Length; i++)
                  {
                      if (existing[i] != bytes[i]) { needWrite = true; break; }
                  }
              }
          }
          if (needWrite)
          {
              System.IO.File.WriteAllBytes(OutputPath, bytes);
          }
        ]]>
      </Code>
    </Task>
  </UsingTask>

  <!--
    ============================================================
                    _DetectCsWinRTNativeComponentReferences

    Collects component project reference paths.
    ============================================================
  -->
  <Target Name="_DetectCsWinRTNativeComponentReferences"
          DependsOnTargets="ResolveProjectReferences;ResolveAssemblyReferences">

    <ItemGroup>
      <_CsWinRTComponentProjectPaths Include="%(_ResolvedProjectReferencePaths.MSBuildSourceProjectFile)"
                                     Condition="'%(_ResolvedProjectReferencePaths.CsWinRTComponent)' == 'true'" />
      <!--
        Component references that expose a non-empty CsWinRTComponentWindowsSdkPackageVersion
        metadata. Filtering both to component refs AND to non-empty metadata is necessary because
        not all components set $(WindowsSdkPackageVersion) at the time Authoring.targets captures
        the metadata (so the value can be empty), and we want to fall through to other sources
        when that's the case.
      -->
      <_CsWinRTComponentSdkVersionRefs Include="@(_ResolvedProjectReferencePaths)"
                                       Condition="'%(_ResolvedProjectReferencePaths.CsWinRTComponent)' == 'true' and '%(_ResolvedProjectReferencePaths.CsWinRTComponentWindowsSdkPackageVersion)' != ''" />
    </ItemGroup>

    <!-- Use the TFM from the first component reference. All referenced components must agree on a TFM for the aggregator's single-TFM build. -->
    <PropertyGroup>
      <_CsWinRTComponentTargetFramework>%(_ResolvedProjectReferencePaths.CsWinRTComponentTargetFramework)</_CsWinRTComponentTargetFramework>
      <_CsWinRTComponentTargetFramework Condition="'$(_CsWinRTComponentTargetFramework)' == ''">net10.0-windows10.0.26100.1</_CsWinRTComponentTargetFramework>
      <!--
        Pick a WindowsSdkPackageVersion for the synthesized aggregator csproj so the SDK-injected
        Microsoft.Windows.SDK.NET.Ref FrameworkReference resolves a known ref-pack version (and
        thus 'Microsoft.Windows.SDK.NET.dll'). Sources, in precedence order:
          1. The consumer's vcxproj (set 'CsWinRTNativeConsumerWindowsSdkPackageVersion').
          2. A component reference's CsWinRTComponentWindowsSdkPackageVersion metadata (filtered
             above to actual components with non-empty metadata).
        If neither is set, the property is omitted from the aggregator and the SDK default applies.
      -->
      <_CsWinRTAggregatorWindowsSdkPackageVersion Condition="'$(CsWinRTNativeConsumerWindowsSdkPackageVersion)' != ''">$(CsWinRTNativeConsumerWindowsSdkPackageVersion)</_CsWinRTAggregatorWindowsSdkPackageVersion>
      <_CsWinRTAggregatorWindowsSdkPackageVersion Condition="'$(_CsWinRTAggregatorWindowsSdkPackageVersion)' == ''">%(_CsWinRTComponentSdkVersionRefs.CsWinRTComponentWindowsSdkPackageVersion)</_CsWinRTAggregatorWindowsSdkPackageVersion>
    </PropertyGroup>

  </Target>

  <!--
    ============================================================
                    CsWinRTGenerateComponentInterop

    Generates a temporary aggregator csproj that references every detected component
    (both as a ProjectReference and as an explicit Reference to the component's
    managed implementation .dll) and builds it with CsWinRTBuildForNativeConsumer=true,
    then copies the resulting merged hosting bundle to the consumer's output directory.
    ============================================================
  -->
  <Target Name="CsWinRTGenerateComponentInterop"
          DependsOnTargets="_DetectCsWinRTNativeComponentReferences"
          BeforeTargets="Link"
          Condition="'$(CsWinRTDisableNativeComponentInterop)' != 'true'">

    <PropertyGroup>
      <_CsWinRTHasComponentReferences Condition="'@(_CsWinRTComponentProjectPaths)' != ''">true</_CsWinRTHasComponentReferences>
    </PropertyGroup>

    <Message Condition="'$(_CsWinRTHasComponentReferences)' != 'true'" Importance="Low" Text="No CsWinRT component project references found. Skipping interop generation." />

    <PropertyGroup Condition="'$(_CsWinRTHasComponentReferences)' == 'true'">
      <_CsWinRTTempProjectDir>$(_CsWinRTNativeConsumerIntermediateDir)</_CsWinRTTempProjectDir>
      <_CsWinRTTempProjectPath>$(_CsWinRTTempProjectDir)CsWinRT.NativeConsumer.csproj</_CsWinRTTempProjectPath>
      <_CsWinRTTempProjectTFMDir>$(_CsWinRTComponentTargetFramework)</_CsWinRTTempProjectTFMDir>
      <!--
        Intermediate output paths for the aggregator. We pin BaseIntermediateOutputPath and the
        config-level IntermediateOutputPath so the post-build Copy step can read merged DLLs
        from a path this targets file owns, independent of any $(Platform)-aware logic the SDK
        applies to its default. We deliberately stop one segment short of the TargetFramework
        because the SDK appends $(TargetFramework)\ to IntermediateOutputPath in its
        post-evaluation pass; the final on-disk path is _CsWinRTTempProjectIntermediateDir.
      -->
      <_CsWinRTTempProjectBaseIntermediateDir>$(_CsWinRTTempProjectDir)obj\</_CsWinRTTempProjectBaseIntermediateDir>
      <_CsWinRTTempProjectIntermediateConfigDir>$(_CsWinRTTempProjectBaseIntermediateDir)$(Configuration)\</_CsWinRTTempProjectIntermediateConfigDir>
      <_CsWinRTTempProjectIntermediateDir>$(_CsWinRTTempProjectIntermediateConfigDir)$(_CsWinRTTempProjectTFMDir)\</_CsWinRTTempProjectIntermediateDir>
      <!--
        Absolute paths to the cswinrt props/targets that the aggregator must <Import>
        directly. The aggregator has no PackageReference to cswinrt, so cswinrt's build
        logic (CsWinRTGen.targets, CsWinRTRemoveWinMDReferences, etc.) is not auto-imported
        through the package convention. Without these explicit imports, the aggregator's
        CsWinRTBuildForNativeConsumer / CsWinRTGenerateInteropAssembly properties have no
        consumer in scope and cswinrtinteropgen never runs.
      -->
      <_CsWinRTPropsForAggregator>$([MSBuild]::NormalizePath('$(MSBuildThisFileDirectory)..\Microsoft.Windows.CsWinRT.props'))</_CsWinRTPropsForAggregator>
      <_CsWinRTTargetsForAggregator>$([MSBuild]::NormalizePath('$(MSBuildThisFileDirectory)..\Microsoft.Windows.CsWinRT.targets'))</_CsWinRTTargetsForAggregator>

      <!--
        Path to the build-time-generated CsWinRT public-key file. We write the public-key blob
        (160 bytes, taken from src/WinRT.Projection.Generator/Generation/ProjectionGenerator.Emit.cs's
        CsWinRTPublicKey field, public-key token = 31bf3856ad364e35) into this file via the
        _WriteCsWinRTAggregatorPublicKey inline task before the aggregator csproj's build runs.
        The aggregator's csproj uses it with PublicSign=true to produce a strong-named
        WinRT.Component.dll whose PublicKeyToken matches the value the interop generator
        hardcodes in InteropReferences.WinRTComponent.
      -->
      <_CsWinRTAggregatorKeyFilePath>$(_CsWinRTTempProjectDir)cswinrt-aggregator-publickey.snk</_CsWinRTAggregatorKeyFilePath>

      <!--
        AOT vs JIT mode for the aggregator sub-build:
        - When the consumer's vcxproj sets PublishAot=true, the aggregator csproj is
          published with PublishAot=true so ILC produces a single native WinRT.Component.dll
          containing every component dll, the projection dlls, and WinRT.Runtime statically
          linked. The native consumer needs ONLY that file at runtime - no .NET runtime,
          no WinRT.Host*.dll, no per-component dlls.
        - Otherwise (default), the aggregator is built (not published). Output is a managed
          WinRT.Component.dll plus the existing JIT runtime closure (host dlls, per-component
          dlls, projection dlls, WinRT.Runtime, .NET runtime resolved from the system).
      -->
      <_CsWinRTAggregatorPublishAot Condition="'$(PublishAot)' == 'true'">true</_CsWinRTAggregatorPublishAot>
      <_CsWinRTAggregatorVerb Condition="'$(_CsWinRTAggregatorPublishAot)' == 'true'">Publish</_CsWinRTAggregatorVerb>
      <_CsWinRTAggregatorVerb Condition="'$(_CsWinRTAggregatorVerb)' == ''">Build</_CsWinRTAggregatorVerb>

      <!--
        For AOT publish, ILC requires a RuntimeIdentifier. Map the vcxproj $(Platform) (Win32,
        x64, ARM64) to the corresponding 'win-X' RID. For non-AOT builds we leave RID empty so
        the SDK builds the framework-dependent managed dll in its usual location.
      -->
      <_CsWinRTAggregatorRuntimeIdentifier Condition="'$(_CsWinRTAggregatorPublishAot)' == 'true' and '$(Platform)' == 'Win32'">win-x86</_CsWinRTAggregatorRuntimeIdentifier>
      <_CsWinRTAggregatorRuntimeIdentifier Condition="'$(_CsWinRTAggregatorPublishAot)' == 'true' and '$(Platform)' == 'x64'">win-x64</_CsWinRTAggregatorRuntimeIdentifier>
      <_CsWinRTAggregatorRuntimeIdentifier Condition="'$(_CsWinRTAggregatorPublishAot)' == 'true' and '$(Platform)' == 'ARM64'">win-arm64</_CsWinRTAggregatorRuntimeIdentifier>

      <!--
        Pin the publish dir to a known location so the copy step has a stable source. The SDK's
        default is bin/Configuration/TargetFramework/RuntimeIdentifier/publish/. We override.
      -->
      <_CsWinRTAggregatorPublishDir Condition="'$(_CsWinRTAggregatorPublishAot)' == 'true'">$(_CsWinRTTempProjectDir)publish\</_CsWinRTAggregatorPublishDir>
    </PropertyGroup>

    <MakeDir Condition="'$(_CsWinRTHasComponentReferences)' == 'true'" Directories="$(_CsWinRTTempProjectDir)" />

    <ItemGroup Condition="'$(_CsWinRTHasComponentReferences)' == 'true'">
      <_CsWinRTTempProjectLines Include="&lt;Project&gt;" />
      <_CsWinRTTempProjectLines Include="  &lt;Import Project=&quot;Sdk.props&quot; Sdk=&quot;Microsoft.NET.Sdk&quot; /&gt;" />
      <_CsWinRTTempProjectLines Include="  &lt;Import Project=&quot;$(_CsWinRTPropsForAggregator)&quot; /&gt;" />
      <_CsWinRTTempProjectLines Include="  &lt;PropertyGroup&gt;" />
      <_CsWinRTTempProjectLines Include="    &lt;TargetFramework&gt;$(_CsWinRTComponentTargetFramework)&lt;/TargetFramework&gt;" />
      <_CsWinRTTempProjectLines Include="    &lt;Platforms&gt;x64%3Bx86%3BARM64&lt;/Platforms&gt;" />
      <!-- Match the consumer-specified WindowsSdkPackageVersion (when set) so the SDK-injected
           Microsoft.Windows.SDK.NET.Ref FrameworkReference resolves a known ref-pack version.
           Otherwise leave it unset and let the SDK pick its default - the same default the
           referenced components used when they were compiled (since both go through the same
           SDK install on the same machine), so the resolved Microsoft.Windows.SDK.NET.dll
           versions match and the SDK's NETSDK1148 cross-version check is satisfied. -->
      <_CsWinRTTempProjectLines Condition="'$(_CsWinRTAggregatorWindowsSdkPackageVersion)' != ''"
                                Include="    &lt;WindowsSdkPackageVersion&gt;$(_CsWinRTAggregatorWindowsSdkPackageVersion)&lt;/WindowsSdkPackageVersion&gt;" />
      <!--
        Pin IntermediateOutputPath / BaseIntermediateOutputPath as project-local properties so
        the aggregator writes outputs to a path Native.targets can read back from. Setting them
        here (rather than as global properties on the parent <MSBuild> call) keeps them scoped
        to the aggregator and stops them from flowing into transitive ProjectReferences such as
        the C++ cswinrt.vcxproj, whose legacy packages.config NuGet resolver breaks if they do.
      -->
      <_CsWinRTTempProjectLines Include="    &lt;BaseIntermediateOutputPath&gt;$(_CsWinRTTempProjectBaseIntermediateDir)&lt;/BaseIntermediateOutputPath&gt;" />
      <_CsWinRTTempProjectLines Include="    &lt;IntermediateOutputPath&gt;$(_CsWinRTTempProjectIntermediateConfigDir)&lt;/IntermediateOutputPath&gt;" />
      <_CsWinRTTempProjectLines Include="    &lt;CsWinRTBuildForNativeConsumer&gt;true&lt;/CsWinRTBuildForNativeConsumer&gt;" />
      <_CsWinRTTempProjectLines Include="    &lt;CsWinRTGenerateInteropAssembly&gt;true&lt;/CsWinRTGenerateInteropAssembly&gt;" />
      <_CsWinRTTempProjectLines Include="    &lt;CsWinRTGenerateProjection&gt;false&lt;/CsWinRTGenerateProjection&gt;" />
      <!--
        AssemblyName=WinRT.Component makes the aggregator's primary CoreCompile output the merged
        WinRT.Component.dll directly, instead of producing it as a side-output of the projection
        generator's in-process Roslyn. This is required so that 'dotnet publish -p:PublishAot=true'
        of the aggregator runs ILC over WinRT.Component.dll itself, materializing the
        [UnmanagedCallersOnly("DllGetActivationFactory")] attribute as a real native PE export.
      -->
      <_CsWinRTTempProjectLines Include="    &lt;AssemblyName&gt;WinRT.Component&lt;/AssemblyName&gt;" />
      <!--
        MergeReferencedActivationFactories=true tells the source generator's EmitManagedExports
        to emit the merged 'ABI.WinRT.Component.ManagedExports.GetActivationFactory' dispatcher
        on the aggregator's primary assembly (walking each referenced component's ManagedExports
        in turn). Combined with PublishAot=true (propagated from the consumer), the source
        generator's EmitNativeExports also emits the [UnmanagedCallersOnly] DllGetActivationFactory
        wrapper - same logic that makes single-component AOT work, just running on the aggregator.
      -->
      <_CsWinRTTempProjectLines Include="    &lt;CsWinRTMergeReferencedActivationFactories&gt;true&lt;/CsWinRTMergeReferencedActivationFactories&gt;" />
      <!--
        AOT plumbing: when the consumer's vcxproj sets PublishAot=true, propagate it (and the
        chosen RuntimeIdentifier + a pinned PublishDir) into the aggregator csproj so its
        publish run produces a single native WinRT.Component.dll with everything statically
        linked.
      -->
      <_CsWinRTTempProjectLines Condition="'$(_CsWinRTAggregatorPublishAot)' == 'true'"
                                Include="    &lt;PublishAot&gt;true&lt;/PublishAot&gt;" />
      <!--
        AOT publish trick (mirrors src/Tests/AuthoringTest/Directory.Build.props):
        - NativeLib=Shared tells ILC to produce a single native .dll.
        - SelfContained=true ensures all managed deps are linked in.
        - OutputType=Exe + CustomNativeMain=true is a workaround to keep TypeMapAssemblyTarget
          attributes alive under AOT until the relevant ILC/runtime fix is available.
          (For a Library publish, ILC currently strips the TypeMap union; for an Exe with
          NativeLib=Shared and CustomNativeMain it preserves them.)
      -->
      <_CsWinRTTempProjectLines Condition="'$(_CsWinRTAggregatorPublishAot)' == 'true'"
                                Include="    &lt;NativeLib&gt;Shared&lt;/NativeLib&gt;" />
      <_CsWinRTTempProjectLines Condition="'$(_CsWinRTAggregatorPublishAot)' == 'true'"
                                Include="    &lt;SelfContained&gt;true&lt;/SelfContained&gt;" />
      <_CsWinRTTempProjectLines Condition="'$(_CsWinRTAggregatorPublishAot)' == 'true'"
                                Include="    &lt;OutputType&gt;Exe&lt;/OutputType&gt;" />
      <_CsWinRTTempProjectLines Condition="'$(_CsWinRTAggregatorPublishAot)' == 'true'"
                                Include="    &lt;CustomNativeMain&gt;true&lt;/CustomNativeMain&gt;" />
      <!-- IsTrimmable=true matches the AuthoringTest project's AOT setup; required for ILC's
           dependency analysis to keep the right closure of types. -->
      <_CsWinRTTempProjectLines Condition="'$(_CsWinRTAggregatorPublishAot)' == 'true'"
                                Include="    &lt;IsTrimmable&gt;true&lt;/IsTrimmable&gt;" />
      <_CsWinRTTempProjectLines Condition="'$(_CsWinRTAggregatorPublishAot)' == 'true'"
                                Include="    &lt;RuntimeIdentifier&gt;$(_CsWinRTAggregatorRuntimeIdentifier)&lt;/RuntimeIdentifier&gt;" />
      <_CsWinRTTempProjectLines Condition="'$(_CsWinRTAggregatorPublishAot)' == 'true'"
                                Include="    &lt;PublishDir&gt;$(_CsWinRTAggregatorPublishDir)&lt;/PublishDir&gt;" />
      <_CsWinRTTempProjectLines Include="    &lt;EnableDefaultItems&gt;false&lt;/EnableDefaultItems&gt;" />
      <_CsWinRTTempProjectLines Include="    &lt;GenerateAssemblyInfo&gt;false&lt;/GenerateAssemblyInfo&gt;" />
      <_CsWinRTTempProjectLines Include="    &lt;ProduceReferenceAssembly&gt;false&lt;/ProduceReferenceAssembly&gt;" />
      <!--
        Public-sign (a.k.a. open-source / delay-sign without skip-verification) the aggregator's
        WinRT.Component.dll with the CsWinRT public key so the resulting assembly identity is:
          WinRT.Component, Version=0.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35

        The interop generator hardcodes that exact assembly reference at
        src/WinRT.Interop.Generator/References/InteropReferences.cs (WinRTComponent property,
        publicKeyOrToken = WellKnownPublicKeyTokens.CsWinRT). When it emits TypeRefs targeting
        the aggregator's ABI types (e.g. ABI.AuthoringTest.BasicStruct), the TypeRef's
        AssemblyRef carries that public key token. Later type-resolution loads the actual
        WinRT.Component.dll via the consumer-supplied component assembly path; if the loaded
        assembly's identity doesn't match the AssemblyRef (PublicKeyToken in particular), the
        resolver throws FileNotFoundException, surfacing as CSWINRTINTEROPGEN0025.

        We use PublicSign rather than full SignAssembly because the package only ships the
        public portion of key.snk (delay-sign style). PublicSign produces a fully verifiable
        strong-named assembly without requiring the private key at consumer build time.
      -->
      <_CsWinRTTempProjectLines Include="    &lt;SignAssembly&gt;true&lt;/SignAssembly&gt;" />
      <_CsWinRTTempProjectLines Include="    &lt;PublicSign&gt;true&lt;/PublicSign&gt;" />
      <_CsWinRTTempProjectLines Include="    &lt;AssemblyOriginatorKeyFile&gt;$(_CsWinRTAggregatorKeyFilePath)&lt;/AssemblyOriginatorKeyFile&gt;" />
      <_CsWinRTTempProjectLines Include="  &lt;/PropertyGroup&gt;" />
      <_CsWinRTTempProjectLines Include="  &lt;ItemGroup&gt;" />
      <_CsWinRTTempProjectLines Include="    &lt;ProjectReference Include=&quot;%(_CsWinRTComponentProjectPaths.Identity)&quot; /&gt;" />
      <!--
        Stub Main entry point: csc requires a Main method when OutputType=Exe (the AOT path).
        ILC's CustomNativeMain bypasses it at native-link time, but csc still validates the
        source. We emit a tiny EntryPoint.cs alongside the synthesized csproj.
      -->
      <_CsWinRTTempProjectLines Condition="'$(_CsWinRTAggregatorPublishAot)' == 'true'"
                                Include="    &lt;Compile Include=&quot;EntryPoint.cs&quot; /&gt;" />
      <!--
        The CsWinRT source generator (AuthoringExportTypesGenerator) flows in transitively from
        the referenced component projects' Microsoft.Windows.CsWinRT package reference, so we
        don't need to add it as an explicit Analyzer item here. (Adding it explicitly produces
        a duplicate-load: the consumer's package-local copy plus the transitive .nuget copy load
        as separate analyzer instances and emit duplicate ManagedExports.g.cs.)
      -->
      <_CsWinRTTempProjectLines Include="  &lt;/ItemGroup&gt;" />
      <_CsWinRTTempProjectLines Include="  &lt;Import Project=&quot;Sdk.targets&quot; Sdk=&quot;Microsoft.NET.Sdk&quot; /&gt;" />
      <_CsWinRTTempProjectLines Include="  &lt;Import Project=&quot;$(_CsWinRTTargetsForAggregator)&quot; /&gt;" />
      <_CsWinRTTempProjectLines Include="&lt;/Project&gt;" />
    </ItemGroup>

    <WriteLinesToFile Condition="'$(_CsWinRTHasComponentReferences)' == 'true'"
                      File="$(_CsWinRTTempProjectPath)"
                      Lines="@(_CsWinRTTempProjectLines)"
                      Overwrite="true" />

    <!--
      AOT only: write a stub EntryPoint.cs alongside the synthesized csproj. csc requires a
      static Main on Exe projects; ILC's CustomNativeMain replaces it natively at link time
      so the body is never executed.
    -->
    <WriteLinesToFile Condition="'$(_CsWinRTHasComponentReferences)' == 'true' and '$(_CsWinRTAggregatorPublishAot)' == 'true'"
                      File="$(_CsWinRTTempProjectDir)EntryPoint.cs"
                      Lines="internal static class CsWinRTNativeConsumerEntryPoint { internal static void Main() { } }"
                      Overwrite="true" />

    <!--
      Write the CsWinRT public-key blob (160 bytes) to a build-time-generated .snk file in the
      aggregator's temp dir. The aggregator's csproj uses it for PublicSign so the resulting
      WinRT.Component.dll has PublicKeyToken=31bf3856ad364e35 - matching what the interop
      generator hardcodes for type lookups against WinRT.Component (see
      src/WinRT.Interop.Generator/References/InteropReferences.cs and the CsWinRTPublicKey
      bytes in src/WinRT.Projection.Generator/Generation/ProjectionGenerator.Emit.cs).
    -->
    <_WriteCsWinRTAggregatorPublicKey Condition="'$(_CsWinRTHasComponentReferences)' == 'true'"
                                      OutputPath="$(_CsWinRTAggregatorKeyFilePath)" />

    <!-- Restore and (Build|Publish) the temporary project. -->
    <MSBuild Condition="'$(_CsWinRTHasComponentReferences)' == 'true'"
             Projects="$(_CsWinRTTempProjectPath)"
             Targets="Restore"
             Properties="Configuration=$(Configuration);Platform=$(Platform);RuntimeIdentifier=$(_CsWinRTAggregatorRuntimeIdentifier)" />

    <MSBuild Condition="'$(_CsWinRTHasComponentReferences)' == 'true'"
             Projects="$(_CsWinRTTempProjectPath)"
             Targets="$(_CsWinRTAggregatorVerb)"
             Properties="Configuration=$(Configuration);Platform=$(Platform);RuntimeIdentifier=$(_CsWinRTAggregatorRuntimeIdentifier);TargetFramework=$(_CsWinRTComponentTargetFramework)" />

    <!--
      Copy generated DLLs to the output directory.
      - JIT (Build): the merged dlls live in the aggregator's intermediate dir; copy each one.
      - AOT (Publish): ILC produces ONE native WinRT.Component.dll in the publish dir with
        every component, projection, and runtime statically linked. Copy that single file.
    -->

    <ItemGroup Condition="'$(_CsWinRTHasComponentReferences)' == 'true' and '$(_CsWinRTAggregatorPublishAot)' != 'true'">
      <_CsWinRTGeneratedDlls Include="$(_CsWinRTTempProjectIntermediateDir)WinRT.Component.dll" Condition="Exists('$(_CsWinRTTempProjectIntermediateDir)WinRT.Component.dll')" />
      <_CsWinRTGeneratedDlls Include="$(_CsWinRTTempProjectIntermediateDir)WinRT.Interop.dll" Condition="Exists('$(_CsWinRTTempProjectIntermediateDir)WinRT.Interop.dll')" />
      <_CsWinRTGeneratedDlls Include="$(_CsWinRTTempProjectIntermediateDir)WinRT.Projection.dll" Condition="Exists('$(_CsWinRTTempProjectIntermediateDir)WinRT.Projection.dll')" />
      <_CsWinRTGeneratedDlls Include="$(_CsWinRTTempProjectIntermediateDir)WinRT.Sdk.Projection.dll" Condition="Exists('$(_CsWinRTTempProjectIntermediateDir)WinRT.Sdk.Projection.dll')" />
      <_CsWinRTGeneratedDlls Include="$(_CsWinRTTempProjectIntermediateDir)WinRT.Sdk.Xaml.Projection.dll" Condition="Exists('$(_CsWinRTTempProjectIntermediateDir)WinRT.Sdk.Xaml.Projection.dll')" />
    </ItemGroup>

    <ItemGroup Condition="'$(_CsWinRTHasComponentReferences)' == 'true' and '$(_CsWinRTAggregatorPublishAot)' == 'true'">
      <_CsWinRTGeneratedDlls Include="$(_CsWinRTAggregatorPublishDir)WinRT.Component.dll" Condition="Exists('$(_CsWinRTAggregatorPublishDir)WinRT.Component.dll')" />
    </ItemGroup>

    <Copy Condition="'$(_CsWinRTHasComponentReferences)' == 'true'" SourceFiles="@(_CsWinRTGeneratedDlls)" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" />

  </Target>

</Project>
